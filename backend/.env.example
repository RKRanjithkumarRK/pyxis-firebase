# ── Firebase Admin (server-side — never expose these) ─────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Firebase Client (browser-side — these are safe to expose) ─────────
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abc123

# ── AI Providers ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIzaSy...
OPENROUTER_API_KEY=sk-or-...
OPENAI_API_KEY=sk-...
HUGGINGFACE_API_KEY=hf_...

# ── Database (Postgres) ────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://pyxis:pyxis@localhost:5432/pyxis
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Cache + Message Broker (Redis) ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20

# ── Celery ────────────────────────────────────────────────────────────
# Defaults to REDIS_URL if not set
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Notifications ──────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Model Routing (optional overrides) ───────────────────────────────
MODEL_REASONING=claude-opus-4-6
MODEL_DAILY=claude-sonnet-4-6
MODEL_REALTIME=claude-haiku-4-5-20251001

# ── Security ──────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ── App ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
